# Selgeo
NEXT_PUBLIC_SELGEO_SNIPPET_URL=https://cdn.selgeo.com/v1/selgeo.js
# Server-side (track-lead API route → POST /api/v1/conversions)
SELGEO_API_URL=https://staging.selgeo.com
# Client-side override for snippet (data-api-url). Routes /v1/clicks etc. to staging
# instead of the snippet's built-in prod URL (which is hardcoded to app.selgeo.com).
NEXT_PUBLIC_SELGEO_API_URL=https://staging.selgeo.com

